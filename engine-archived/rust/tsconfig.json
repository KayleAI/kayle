{
  "include": ["./**/*", "./src/**/*"],
  "exclude": ["node_modules", "dist", "target", "build"],
  "compilerOptions": {
    "target": "es2022",
    "module": "ES2022",
    "rootDir": "./",
    "types": [],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
  }
}