datasource db {
  provider  = "postgresql"
  url       = env("HYPERDRIVE")
  directUrl = env("DIRECT_DATABASE_URL")
}
 
generator client {
  // Corresponds to the cargo alias created earlier
  provider      = "cargo prisma"
  // The location to generate the client. Is relative to the position of the schema
  output        = "../src/prisma.rs"
}